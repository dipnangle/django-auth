# ─────────────────────────────────────────────
# Django Core
# ─────────────────────────────────────────────
DJANGO_ENV=development
DJANGO_SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─────────────────────────────────────────────
# Deployment Mode
# ─────────────────────────────────────────────
DEPLOYMENT_MODE=saas  # or: self_hosted

# ─────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────
DB_NAME=platform_dev
DB_USER=platform_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432
# DB_REPLICA_HOST=  # Optional read replica

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_SIGNING_KEY=your-jwt-signing-key
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7
JWT_ISSUER=platform
JWT_AUDIENCE=platform-api

# ─────────────────────────────────────────────
# Celery
# ─────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/3

# ─────────────────────────────────────────────
# Email
# ─────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@yourplatform.com
EMAIL_SUBJECT_PREFIX=[Platform]
# For production (SendGrid):
# EMAIL_BACKEND=anymail.backends.sendgrid.EmailBackend
# SENDGRID_API_KEY=your-sendgrid-key

# ─────────────────────────────────────────────
# Platform
# ─────────────────────────────────────────────
PLATFORM_NAME=YourPlatform
FRONTEND_URL=http://localhost:3000
SUPPORT_EMAIL=support@yourplatform.com

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────
RL_LOGIN_ATTEMPTS=5
RL_LOGIN_WINDOW=300
RL_REGISTER_ATTEMPTS=10
RL_REGISTER_WINDOW=3600

# ─────────────────────────────────────────────
# Account Lockout
# ─────────────────────────────────────────────
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# ─────────────────────────────────────────────
# 2FA
# ─────────────────────────────────────────────
TOTP_ISSUER=YourPlatform

# ─────────────────────────────────────────────
# Production Only
# ─────────────────────────────────────────────
# SENTRY_DSN=https://your-sentry-dsn
# USE_S3=True
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1
